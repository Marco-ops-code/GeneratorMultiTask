<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GeneratorMultiTask.ResultsPage"
             Title="Résultats"
             BackgroundColor="{AppThemeBinding Light={StaticResource ExamSurface}, Dark={StaticResource ExamBackground}}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16" RowSpacing="14">

        <Border Grid.Row="0"
                StrokeThickness="1"
                Stroke="{AppThemeBinding Light={StaticResource ExamStroke}, Dark={StaticResource ExamStrokeDark}}"
                BackgroundColor="{AppThemeBinding Light={StaticResource ExamCard}, Dark={StaticResource ExamCardDark}}"
                Padding="18"
                StrokeShape="RoundRectangle 16">
            <VerticalStackLayout Spacing="8">
                <Label x:Name="ScoreTitle"
                       FontSize="22"
                       FontFamily="OpenSansSemibold"
                       TextColor="{AppThemeBinding Light={StaticResource ExamInk}, Dark={StaticResource ExamMutedFg}}" />
                <Label x:Name="ScoreDetail"
                       FontSize="14"
                       TextColor="{AppThemeBinding Light={StaticResource ExamMutedInk}, Dark={StaticResource ExamMutedFg}}"
                       LineBreakMode="WordWrap" />
            </VerticalStackLayout>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="DetailStack" Spacing="12" />
        </ScrollView>

        <Button Grid.Row="2"
                Text="Nouvelle épreuve"
                Clicked="OnHomeClicked"
                BackgroundColor="{StaticResource ExamAccent}"
                TextColor="{StaticResource ExamAccentFg}"
                FontFamily="OpenSansSemibold"
                CornerRadius="14"
                Padding="18,14" />
    </Grid>
</ContentPage>
